{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MediaVault",
  "version": "0.1.0",
  "identifier": "dev.fenron.mediavault",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MediaVault",
        "url": "mediavault://localhost/index.html",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": ["icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
